# Point this at your Railway backend URL once deployed
NEXT_PUBLIC_API_URL=https://your-backend.up.railway.app

# Paystack PUBLIC key (safe to expose). Embedded at build time — rebuild the
# frontend after changing it. Start with pk_test_..., switch to pk_live_... to go live.
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
