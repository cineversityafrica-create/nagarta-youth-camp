<%- include('../partials/head', { title: 'Payment Portal' }) %>
<%- include('../partials/sidebar', { page: 'payments' }) %>

<% if (typeof paystackKey !== 'undefined' && paystackKey) { %>
  <script src="https://js.paystack.co/v1/inline.js"></script>
<% } %>

<main class="main-content p-4 md:p-8 min-h-screen">

  <!-- Header -->
  <div class="mb-8">
    <p class="text-xs tracking-widest uppercase text-gold font-semibold mb-1">Admin</p>
    <h2 class="font-serif text-3xl font-semibold text-maroon italic">Payment Portal</h2>
  </div>

  <!-- Search bar -->
  <form method="GET" action="/admin/payments" class="mb-8">
    <div class="flex gap-3 max-w-lg">
      <input type="text" name="ref" value="<%= typeof registration !== 'undefined' && registration ? registration.referenceCode : (typeof query !== 'undefined' ? query : '') %>"
        placeholder="Enter reference code e.g. NAG12345ABCD"
        class="flex-1 px-4 py-3 border border-beige rounded-lg bg-white text-maroon text-sm font-mono focus:outline-none focus:ring-2 focus:ring-gold uppercase"
        autocomplete="off" style="text-transform:uppercase;" />
      <button type="submit"
        class="bg-gold text-maroon px-6 py-3 rounded-lg text-sm font-semibold tracking-wider uppercase hover:bg-amber-500 transition-colors">
        Search
      </button>
    </div>
  </form>

  <!-- Error / success alerts -->
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="bg-red-50 border border-red-200 text-red-700 rounded-lg px-5 py-3 text-sm mb-6"><%= error %></div>
  <% } %>
  <% if (typeof success !== 'undefined' && success) { %>
    <div class="bg-green-50 border border-green-200 text-green-700 rounded-lg px-5 py-3 text-sm mb-6"><%= success %></div>
  <% } %>

  <% if (typeof registration !== 'undefined' && registration) { %>

    <!-- ══════════════════════════════════════════════════════ -->
    <!--  TOP ROW: Camper card + Quick actions                 -->
    <!-- ══════════════════════════════════════════════════════ -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">

      <!-- Camper summary card -->
      <div class="lg:col-span-2 bg-white rounded-xl shadow-sm border border-gray-100 p-6 flex gap-5">
        <!-- Photo -->
        <div class="flex-shrink-0">
          <% if (registration.child && registration.child.photo) { %>
            <img src="<%= registration.child.photo %>" alt="Camper"
              class="w-24 h-24 rounded-xl object-cover border-2 border-beige cursor-pointer hover:opacity-90 transition-opacity"
              onclick="openPhotoModal(this.src)" />
          <% } else { %>
            <div class="w-24 h-24 rounded-xl bg-gray-100 flex items-center justify-center text-gray-300">
              <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
            </div>
          <% } %>
        </div>
        <!-- Info -->
        <div class="flex-1 min-w-0">
          <p class="font-serif text-xl font-semibold text-maroon"><%= registration.child ? registration.child.name : registration.user.name %></p>
          <p class="text-xs text-burgundy/60 mb-3">
            <% if (registration.child && registration.child.age) { %><%= registration.child.age %> yrs · <% } %>
            <% if (registration.child && registration.child.school) { %><%= registration.child.school %><% } %>
          </p>
          <dl class="grid grid-cols-2 gap-x-4 gap-y-1.5 text-xs">
            <div><span class="text-burgundy/50">Reference:</span> <span class="font-mono font-semibold text-maroon"><%= registration.referenceCode %></span></div>
            <div><span class="text-burgundy/50">Parent:</span> <span class="text-maroon"><%= registration.parentName || registration.user.name %></span></div>
            <div><span class="text-burgundy/50">Email:</span> <span class="text-maroon break-all"><%= registration.user.email %></span></div>
            <div><span class="text-burgundy/50">Phone:</span> <span class="text-maroon"><%= registration.parentPhone || registration.user.phone || '—' %></span></div>
            <div>
              <span class="text-burgundy/50">Status:</span>
              <span class="ml-1 px-2 py-0.5 rounded-full text-xs font-semibold
                <%= registration.status === 'CONFIRMED' ? 'bg-green-100 text-green-700' :
                   registration.status === 'PENDING'    ? 'bg-amber-100 text-amber-700' :
                   registration.status === 'WAITLISTED' ? 'bg-blue-100 text-blue-700'  :
                                                          'bg-red-100 text-red-600' %>">
                <%= registration.status %>
              </span>
            </div>
            <div>
              <span class="text-burgundy/50">Payment:</span>
              <span class="ml-1 px-2 py-0.5 rounded-full text-xs font-semibold
                <%= registration.paymentStatus === 'PAID'    ? 'bg-green-100 text-green-700' :
                   registration.paymentStatus === 'PARTIAL'  ? 'bg-amber-100 text-amber-700' :
                                                               'bg-gray-100 text-gray-500' %>">
                <%= registration.paymentStatus %>
              </span>
            </div>
          </dl>
        </div>
      </div>

      <!-- Quick actions -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 flex flex-col gap-3">
        <p class="text-xs tracking-wider uppercase text-gray-400 font-semibold mb-1">Quick Actions</p>

        <!-- Print receipt -->
        <button type="button" onclick="printReceipt()"
          class="w-full flex items-center gap-2 bg-maroon text-gold px-4 py-2.5 rounded-lg text-xs font-semibold tracking-wider uppercase hover:bg-burgundy transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/>
          </svg>
          Print Receipt
        </button>

        <!-- Send receipt email (server-side) -->
        <form method="POST" action="/admin/payments/<%= registration.id %>/send-receipt" id="sendReceiptForm">
          <input type="hidden" name="packingItems" id="packingItemsInput" value="" />
          <button type="submit"
            class="w-full flex items-center gap-2 bg-gold text-maroon px-4 py-2.5 rounded-lg text-xs font-semibold tracking-wider uppercase hover:bg-amber-500 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            Send Receipt by Email
          </button>
        </form>

        <!-- Open mail client -->
        <a href="mailto:<%= registration.user.email %>?subject=NAGARTA Youth Camp 2026 — Reference <%= registration.referenceCode %>&body=Dear <%= registration.parentName || registration.user.name %>,%0A%0AThank you for registering for NAGARTA Youth Camp 2026.%0A%0AYour reference code is: <%= registration.referenceCode %>%0A%0APlease keep this safe for camp check-in.%0A%0ANAGARTA Youth Camp Team"
          class="w-full flex items-center gap-2 border border-gold/60 text-gold px-4 py-2.5 rounded-lg text-xs font-semibold tracking-wider uppercase hover:bg-gold/10 transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0l-8 4-8-4"/>
          </svg>
          Open Mail App
        </a>
      </div>
    </div>

    <!-- ══════════════════════════════════════════════════════ -->
    <!--  PACKING LIST                                         -->
    <!-- ══════════════════════════════════════════════════════ -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-6">
      <div class="flex items-center justify-between mb-4">
        <div>
          <p class="text-xs tracking-wider uppercase text-gray-400 font-semibold mb-0.5">Camp Checklist</p>
          <h3 class="font-serif text-lg font-semibold text-maroon">Packing List</h3>
        </div>
        <div class="flex gap-2">
          <button type="button" onclick="selectAllPacking(true)"
            class="text-xs text-gold hover:underline font-semibold">Select All</button>
          <span class="text-gray-300">|</span>
          <button type="button" onclick="selectAllPacking(false)"
            class="text-xs text-burgundy/50 hover:underline">Clear</button>
        </div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2" id="packingList">
        <% [
          'Quran / Bible / Prayer book',
          'Prayer mat',
          'Notebook & pen',
          '3–5 changes of clothing',
          'Comfortable walking shoes',
          'Sandals / flip flops',
          'Towel & washcloth',
          'Soap, toothbrush & toothpaste',
          'Shampoo & deodorant',
          'Water bottle (1.5L minimum)',
          'Pillow & bed sheet',
          'Light blanket',
          'Rain jacket or light coat',
          'Torch / flashlight + batteries',
          'Sunscreen & insect repellent',
          'Prescribed medications (labelled)',
          'Small backpack / day bag',
          'Cash for personal needs',
          'Camp identity badge (this receipt)'
        ].forEach(function(item) { %>
          <label class="flex items-start gap-2.5 p-2.5 rounded-lg hover:bg-gray-50 cursor-pointer transition-colors packing-item">
            <input type="checkbox" value="<%= item %>"
              class="packing-check mt-0.5 w-4 h-4 rounded border-gray-300 text-gold accent-amber-600 flex-shrink-0" />
            <span class="text-sm text-maroon"><%= item %></span>
          </label>
        <% }) %>
      </div>
    </div>

    <!-- ══════════════════════════════════════════════════════ -->
    <!--  RECORD PAYMENT                                       -->
    <!-- ══════════════════════════════════════════════════════ -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-6">
      <p class="text-xs tracking-wider uppercase text-gray-400 font-semibold mb-1">Record Payment</p>
      <h3 class="font-serif text-lg font-semibold text-maroon mb-5">Accept Payment</h3>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

        <!-- Cash payment form -->
        <div class="border border-beige rounded-xl p-5">
          <p class="text-xs tracking-wider uppercase text-burgundy/60 font-semibold mb-4 flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/>
            </svg>
            Cash / Manual Payment
          </p>
          <form method="POST" action="/admin/payments/<%= registration.id %>/record" class="space-y-3">
            <input type="hidden" name="method" value="CASH" />
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-xs font-semibold text-burgundy mb-1">Amount (₵)</label>
                <input type="number" name="amount" min="0" step="0.01" placeholder="0.00" required
                  class="w-full px-3 py-2.5 border border-beige rounded-lg text-sm text-maroon focus:outline-none focus:ring-2 focus:ring-gold" />
              </div>
              <div>
                <label class="block text-xs font-semibold text-burgundy mb-1">Update Status</label>
                <select name="paymentStatus"
                  class="w-full px-3 py-2.5 border border-beige rounded-lg text-sm text-maroon bg-white focus:outline-none focus:ring-2 focus:ring-gold">
                  <option value="PARTIAL">Partial</option>
                  <option value="PAID" selected>Paid in Full</option>
                </select>
              </div>
            </div>
            <div>
              <label class="block text-xs font-semibold text-burgundy mb-1">Note (optional)</label>
              <input type="text" name="note" placeholder="e.g. Cash received at front desk"
                class="w-full px-3 py-2.5 border border-beige rounded-lg text-sm text-maroon focus:outline-none focus:ring-2 focus:ring-gold" />
            </div>
            <button type="submit"
              class="w-full bg-maroon text-gold py-2.5 rounded-lg text-xs font-semibold tracking-wider uppercase hover:bg-burgundy transition-colors">
              Record Cash Payment
            </button>
          </form>
        </div>

        <!-- Online payment (Paystack) -->
        <div class="border border-beige rounded-xl p-5">
          <p class="text-xs tracking-wider uppercase text-burgundy/60 font-semibold mb-4 flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
            </svg>
            Visa Card / Mobile Money
          </p>

          <% if (typeof paystackKey !== 'undefined' && paystackKey) { %>
            <!-- Paystack form (hidden; submitted after Paystack callback) -->
            <form method="POST" action="/admin/payments/<%= registration.id %>/record" id="paystackForm" class="space-y-3">
              <input type="hidden" name="paystackRef" id="paystackRef" />
              <input type="hidden" name="paymentStatus" value="PAID" />
              <input type="hidden" name="method" id="paystackMethod" value="VISA" />
              <div>
                <label class="block text-xs font-semibold text-burgundy mb-1">Amount (₵)</label>
                <input type="number" id="onlineAmount" min="1" step="0.01" placeholder="0.00"
                  class="w-full px-3 py-2.5 border border-beige rounded-lg text-sm text-maroon focus:outline-none focus:ring-2 focus:ring-gold" />
                <input type="hidden" name="amount" id="onlineAmountHidden" />
              </div>
              <div class="grid grid-cols-2 gap-3">
                <button type="button"
                  onclick="initiatePaystack('card')"
                  class="flex items-center justify-center gap-2 bg-blue-600 text-white py-2.5 rounded-lg text-xs font-semibold tracking-wider uppercase hover:bg-blue-700 transition-colors">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
                  </svg>
                  Visa / Card
                </button>
                <button type="button"
                  onclick="initiatePaystack('mobile_money')"
                  class="flex items-center justify-center gap-2 bg-amber-600 text-white py-2.5 rounded-lg text-xs font-semibold tracking-wider uppercase hover:bg-amber-700 transition-colors">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/>
                  </svg>
                  Mobile Money
                </button>
              </div>
            </form>
          <% } else { %>
            <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 text-sm text-amber-800">
              <p class="font-semibold mb-1">Paystack not configured</p>
              <p class="text-xs">Set <code class="bg-amber-100 px-1 rounded">PAYSTACK_PUBLIC_KEY</code> on Render to enable card and mobile money payments.</p>
            </div>
          <% } %>

          <!-- Mobile money manual instructions -->
          <div class="mt-4 bg-gray-50 rounded-lg p-4">
            <p class="text-xs font-semibold text-burgundy mb-2">Manual Mobile Money Numbers</p>
            <div class="space-y-1 text-xs text-maroon">
              <div class="flex justify-between"><span class="text-gray-400">MTN MoMo</span><span class="font-mono">024 000 0000</span></div>
              <div class="flex justify-between"><span class="text-gray-400">Vodafone Cash</span><span class="font-mono">020 000 0000</span></div>
              <div class="flex justify-between"><span class="text-gray-400">AirtelTigo</span><span class="font-mono">027 000 0000</span></div>
            </div>
            <p class="text-xs text-gray-400 mt-2">Update numbers in the admin panel as needed.</p>
          </div>
        </div>

      </div>
    </div>

    <!-- ══════════════════════════════════════════════════════ -->
    <!--  TRANSACTION HISTORY                                  -->
    <!-- ══════════════════════════════════════════════════════ -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
      <p class="text-xs tracking-wider uppercase text-gray-400 font-semibold mb-4">Transaction History</p>
      <% if (registration.transactions && registration.transactions.length > 0) { %>
        <% var totalPaid = registration.transactions.reduce(function(s, t) { return s + t.amount; }, 0); %>
        <table class="w-full text-sm mb-3">
          <thead>
            <tr class="border-b border-gray-100">
              <th class="text-left text-xs tracking-wider uppercase text-gray-400 pb-2 font-semibold">Date</th>
              <th class="text-left text-xs tracking-wider uppercase text-gray-400 pb-2 font-semibold">Method</th>
              <th class="text-left text-xs tracking-wider uppercase text-gray-400 pb-2 font-semibold">Reference</th>
              <th class="text-left text-xs tracking-wider uppercase text-gray-400 pb-2 font-semibold">Note</th>
              <th class="text-right text-xs tracking-wider uppercase text-gray-400 pb-2 font-semibold">Amount</th>
            </tr>
          </thead>
          <tbody>
            <% registration.transactions.forEach(function(t) { %>
              <tr class="border-b border-gray-50 hover:bg-gray-50">
                <td class="py-2 text-xs text-burgundy"><%= new Date(t.createdAt).toLocaleDateString('en-GB') %></td>
                <td class="py-2">
                  <span class="text-xs px-2 py-0.5 rounded-full font-semibold
                    <%= t.method === 'VISA' ? 'bg-blue-100 text-blue-700' :
                       t.method === 'MOBILE_MONEY' ? 'bg-amber-100 text-amber-700' :
                                                     'bg-gray-100 text-gray-600' %>">
                    <%= t.method.replace('_', ' ') %>
                  </span>
                </td>
                <td class="py-2 font-mono text-xs text-burgundy"><%= t.reference || '—' %></td>
                <td class="py-2 text-xs text-gray-500"><%= t.note || '—' %></td>
                <td class="py-2 text-right font-semibold text-maroon text-sm">₵<%= (t.amount / 100).toFixed(2) %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
        <div class="flex justify-end">
          <div class="bg-maroon/5 rounded-lg px-5 py-2 text-sm">
            <span class="text-burgundy/60 mr-3">Total Paid:</span>
            <span class="font-serif font-semibold text-maroon text-lg">₵<%= (totalPaid / 100).toFixed(2) %></span>
          </div>
        </div>
      <% } else { %>
        <p class="text-sm text-burgundy/40 italic text-center py-6">No payment transactions recorded yet.</p>
      <% } %>
    </div>

  <% } else if (typeof error === 'undefined' || !error) { %>
    <!-- Empty search state -->
    <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-16 text-center max-w-lg mx-auto">
      <div class="w-16 h-16 bg-gold/10 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg class="w-8 h-8 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
        </svg>
      </div>
      <p class="font-serif text-xl font-semibold text-maroon mb-2">Payment Portal</p>
      <p class="text-sm text-burgundy/60">Enter a registration reference code above to look up a camper and process or record their payment.</p>
    </div>
  <% } %>

</main>

<!-- Photo lightbox -->
<div id="photo-modal" onclick="closePhotoModal()"
  style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.85);cursor:zoom-out"
  class="flex items-center justify-center p-6">
  <div onclick="event.stopPropagation()" class="relative max-w-xl w-full">
    <img id="photo-modal-img" src="" alt="Camper Photo"
      class="w-full max-h-[80vh] object-contain rounded-xl shadow-2xl" />
    <div class="flex gap-3 mt-4 justify-center">
      <button onclick="closePhotoModal()"
        class="border border-white/30 text-white px-5 py-2 rounded-full text-xs font-semibold tracking-wider uppercase hover:bg-white/10 transition-colors">
        Close
      </button>
    </div>
  </div>
</div>

<script>
  /* ── Photo lightbox ─────────────────────── */
  function openPhotoModal(src) {
    document.getElementById('photo-modal-img').src = src;
    document.getElementById('photo-modal').style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }
  function closePhotoModal() {
    document.getElementById('photo-modal').style.display = 'none';
    document.getElementById('photo-modal-img').src = '';
    document.body.style.overflow = '';
  }
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closePhotoModal(); });

  /* ── Packing list helpers ───────────────── */
  function selectAllPacking(checked) {
    document.querySelectorAll('.packing-check').forEach(function(cb) { cb.checked = checked; });
  }
  function getCheckedItems() {
    return Array.from(document.querySelectorAll('.packing-check:checked')).map(function(cb) { return cb.value; });
  }

  /* ── Sync packing items into send-receipt form ── */
  var sendForm = document.getElementById('sendReceiptForm');
  if (sendForm) {
    sendForm.addEventListener('submit', function() {
      document.getElementById('packingItemsInput').value = getCheckedItems().join(',');
    });
  }

  /* ── Paystack ───────────────────────────── */
  function initiatePaystack(channel) {
    var amountGhs = parseFloat(document.getElementById('onlineAmount').value);
    if (!amountGhs || amountGhs <= 0) { alert('Please enter an amount first.'); return; }
    document.getElementById('onlineAmountHidden').value = amountGhs;
    document.getElementById('paystackMethod').value = channel === 'card' ? 'VISA' : 'MOBILE_MONEY';

    <% if (typeof paystackKey !== 'undefined' && paystackKey) { %>
    var handler = PaystackPop.setup({
      key:      '<%= paystackKey %>',
      email:    '<%= registration ? registration.user.email : "" %>',
      amount:   Math.round(amountGhs * 100),
      currency: 'GHS',
      channels: [channel === 'card' ? 'card' : 'mobile_money'],
      ref:      'NAG-' + new Date().getTime(),
      callback: function(response) {
        document.getElementById('paystackRef').value = response.reference;
        document.getElementById('paystackForm').submit();
      },
      onClose: function() {}
    });
    handler.openIframe();
    <% } else { %>
    alert('Paystack public key not configured. Please set PAYSTACK_PUBLIC_KEY on Render.');
    <% } %>
  }

  /* ── Print receipt ──────────────────────── */
  function printReceipt() {
    var checked = getCheckedItems();
    <% if (typeof registration !== 'undefined' && registration) { %>
    var d = {
      name:             '<%= registration.child ? (registration.child.name || "").replace(/'/g,"\'") : (registration.user.name || "").replace(/'/g,"\'") %>',
      age:              '<%= registration.child && registration.child.age ? registration.child.age : "" %>',
      school:           '<%= registration.child && registration.child.school ? registration.child.school.replace(/'/g,"\'") : "" %>',
      dietaryNeeds:     '<%= registration.child && registration.child.dietaryNeeds ? registration.child.dietaryNeeds.replace(/'/g,"\'") : "" %>',
      medicalNotes:     '<%= registration.child && registration.child.medicalNotes ? registration.child.medicalNotes.replace(/'/g,"\'") : "" %>',
      emergencyContact: '<%= registration.child && registration.child.emergencyContact ? registration.child.emergencyContact.replace(/'/g,"\'") : "" %>',
      photo:            '<%= registration.child && registration.child.photo ? registration.child.photo : "" %>',
      referenceCode:    '<%= registration.referenceCode %>',
      status:           '<%= registration.status %>',
      paymentStatus:    '<%= registration.paymentStatus %>',
      parentName:       '<%= (registration.parentName || registration.user.name || "").replace(/'/g,"\'") %>',
      parentPhone:      '<%= (registration.parentPhone || registration.user.phone || "").replace(/'/g,"\'") %>',
      parentAddress:    '<%= (registration.parentAddress || "").replace(/'/g,"\'") %>',
      parentEmail:      '<%= registration.user.email %>',
      transactions:     <%- JSON.stringify(registration.transactions.map(function(t){ return { method: t.method, amount: t.amount, reference: t.reference, createdAt: t.createdAt }; })) %>,
      packingItems:     checked
    };

    var photoHtml = d.photo
      ? '<img src="'+d.photo+'" style="width:140px;height:140px;object-fit:cover;border-radius:8px;border:2px solid #decbb2;" />'
      : '<div style="width:140px;height:140px;border-radius:8px;border:2px dashed #decbb2;display:flex;align-items:center;justify-content:center;color:#aaa;font-size:12px;">No Photo</div>';

    var txRows = d.transactions.map(function(t) {
      return '<tr><td style="padding:3px 10px 3px 0;font-size:11px;color:#531c22;">'
        + new Date(t.createdAt).toLocaleDateString('en-GB') + '</td>'
        + '<td style="padding:3px 10px 3px 0;font-size:11px;">' + t.method.replace('_',' ') + '</td>'
        + '<td style="padding:3px 10px 3px 0;font-size:11px;font-family:monospace;">' + (t.reference||'—') + '</td>'
        + '<td style="padding:3px 0;font-size:11px;text-align:right;font-weight:600;">₵' + (t.amount/100).toFixed(2) + '</td></tr>';
    }).join('');

    var packList = d.packingItems.length
      ? '<ul style="columns:2;gap:20px;margin:0;padding-left:16px;">'
        + d.packingItems.map(function(i){return '<li style="font-size:11px;margin-bottom:3px;">'+i+'</li>';}).join('')
        + '</ul>'
      : '<p style="font-size:11px;color:#aaa;font-style:italic;">No items selected.</p>';

    var totalPaid = d.transactions.reduce(function(s,t){return s+t.amount;},0);

    var html = '<!DOCTYPE html><html><head><title>NAGARTA Receipt — '+d.referenceCode+'</title>'
      + '<style>body{font-family:Georgia,serif;margin:0;padding:30px;color:#301317;background:#fff;font-size:12px;}'
      + '@media print{body{padding:15px;}}'
      + '.hdr{background:#301317;color:#cba36b;padding:14px 20px;border-radius:8px;margin-bottom:20px;display:flex;align-items:center;justify-content:space-between;}'
      + '.hdr h1{margin:0;font-size:20px;letter-spacing:2px;} .hdr p{margin:0;font-size:9px;letter-spacing:3px;text-transform:uppercase;opacity:.65;}'
      + '.row{display:flex;gap:24px;margin-bottom:18px;}'
      + '.sec-title{font-size:9px;letter-spacing:3px;text-transform:uppercase;color:#531c22;font-family:Arial,sans-serif;margin:0 0 6px;border-bottom:1px solid #decbb2;padding-bottom:3px;}'
      + 'table{border-collapse:collapse;width:100%;} td{padding:3px 8px 3px 0;vertical-align:top;}'
      + '.badge{display:inline-block;padding:2px 8px;border-radius:20px;font-size:9px;font-weight:700;font-family:Arial,sans-serif;letter-spacing:1px;text-transform:uppercase;background:#decbb2;color:#301317;}'
      + '.ref{font-family:monospace;font-size:14px;font-weight:700;color:#531c22;letter-spacing:2px;}'
      + '.footer{margin-top:20px;border-top:1px solid #decbb2;padding-top:8px;font-size:9px;color:#aaa;text-align:center;}'
      + '</style></head><body>'
      + '<div class="hdr"><div><h1>NAGARTA Youth Camp 2026</h1><p>Official Registration Receipt</p></div>'
      + '<div style="text-align:right;font-size:10px;opacity:.65;">Printed '+new Date().toLocaleDateString('en-GB')+'</div></div>'
      + '<div class="row">'
      +   '<div style="flex-shrink:0;">'+photoHtml+'<div style="margin-top:8px;text-align:center;"><span class="badge">'+d.status+'</span> <span class="badge">'+d.paymentStatus+'</span></div></div>'
      +   '<div style="flex:1;">'
      +     '<p class="sec-title">Camper Details</p>'
      +     '<table>'
      +       (d.name ? '<tr><td style="color:#531c22;font-weight:600;white-space:nowrap;">Full Name</td><td>'+d.name+'</td></tr>' : '')
      +       (d.age  ? '<tr><td style="color:#531c22;font-weight:600;white-space:nowrap;">Age</td><td>'+d.age+' years</td></tr>' : '')
      +       (d.school ? '<tr><td style="color:#531c22;font-weight:600;white-space:nowrap;">School</td><td>'+d.school+'</td></tr>' : '')
      +       (d.dietaryNeeds ? '<tr><td style="color:#531c22;font-weight:600;white-space:nowrap;">Dietary</td><td>'+d.dietaryNeeds+'</td></tr>' : '')
      +       (d.medicalNotes ? '<tr><td style="color:#531c22;font-weight:600;white-space:nowrap;">Medical</td><td>'+d.medicalNotes+'</td></tr>' : '')
      +       (d.emergencyContact ? '<tr><td style="color:#531c22;font-weight:600;white-space:nowrap;">Emergency</td><td>'+d.emergencyContact+'</td></tr>' : '')
      +     '</table>'
      +     '<br><p class="sec-title">Parent / Guardian</p>'
      +     '<table>'
      +       (d.parentName ? '<tr><td style="color:#531c22;font-weight:600;white-space:nowrap;">Name</td><td>'+d.parentName+'</td></tr>' : '')
      +       (d.parentPhone ? '<tr><td style="color:#531c22;font-weight:600;white-space:nowrap;">Phone</td><td>'+d.parentPhone+'</td></tr>' : '')
      +       (d.parentEmail ? '<tr><td style="color:#531c22;font-weight:600;white-space:nowrap;">Email</td><td>'+d.parentEmail+'</td></tr>' : '')
      +       (d.parentAddress ? '<tr><td style="color:#531c22;font-weight:600;white-space:nowrap;">Address</td><td>'+d.parentAddress+'</td></tr>' : '')
      +     '</table>'
      +     '<br><p class="sec-title">Reference</p><p class="ref">'+d.referenceCode+'</p>'
      +   '</div>'
      + '</div>'
      + (txRows ? '<p class="sec-title">Payment Transactions</p><table><thead><tr>'
        + '<th style="text-align:left;font-size:9px;text-transform:uppercase;color:#aaa;padding-bottom:4px;">Date</th>'
        + '<th style="text-align:left;font-size:9px;text-transform:uppercase;color:#aaa;padding-bottom:4px;">Method</th>'
        + '<th style="text-align:left;font-size:9px;text-transform:uppercase;color:#aaa;padding-bottom:4px;">Reference</th>'
        + '<th style="text-align:right;font-size:9px;text-transform:uppercase;color:#aaa;padding-bottom:4px;">Amount</th>'
        + '</tr></thead><tbody>'+txRows+'</tbody></table>'
        + '<p style="text-align:right;font-weight:700;font-size:13px;margin-top:6px;color:#301317;">Total: ₵'+(totalPaid/100).toFixed(2)+'</p>' : '')
      + '<br><p class="sec-title">Packing List (tick before leaving home)</p>'+packList
      + '<div class="footer">NAGARTA Youth Camp 2026 &nbsp;·&nbsp; Official Receipt &nbsp;·&nbsp; '+d.referenceCode+'</div>'
      + '</body></html>';

    var win = window.open('','_blank','width=820,height=700');
    win.document.write(html);
    win.document.close();
    win.focus();
    win.onload = function(){ win.print(); };
    <% } %>
  }
</script>
</body>
</html>
