<%- include('../partials/head', { title: 'Registrations' }) %>
<%- include('../partials/sidebar', { page: 'registrations' }) %>

<main class="ml-64 p-8">
  <div class="flex items-center justify-between mb-8">
    <div>
      <p class="text-xs tracking-widest uppercase text-gold font-semibold mb-1">Manage</p>
      <h2 class="font-serif text-3xl font-semibold text-maroon italic">Registrations</h2>
    </div>
    <a href="/admin/registrations/export"
      class="bg-gold text-maroon px-5 py-2 rounded text-sm font-semibold tracking-wider uppercase hover:bg-amber-500 transition-colors">
      Export CSV
    </a>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 border-b border-gray-100">
        <tr>
          <th class="text-left text-xs tracking-wider uppercase px-4 py-3 font-semibold text-gray-400">Photo</th>
          <th class="text-left text-xs tracking-wider uppercase px-4 py-3 font-semibold text-gray-400">Reference</th>
          <th class="text-left text-xs tracking-wider uppercase px-4 py-3 font-semibold text-gray-400">Attendee</th>
          <th class="text-left text-xs tracking-wider uppercase px-4 py-3 font-semibold text-gray-400">Registered By</th>
          <th class="text-left text-xs tracking-wider uppercase px-4 py-3 font-semibold text-gray-400">Status</th>
          <th class="text-left text-xs tracking-wider uppercase px-4 py-3 font-semibold text-gray-400">Payment</th>
          <th class="text-left text-xs tracking-wider uppercase px-4 py-3 font-semibold text-gray-400">Date</th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody>
        <% registrations.forEach(reg => { %>
          <tr class="border-b border-gray-50 hover:bg-gray-50 transition-colors">
            <td class="px-4 py-3">
              <% if (reg.child && reg.child.photo) { %>
                <img src="<%= reg.child.photo %>" alt="Attendee"
                  class="w-10 h-10 rounded-full object-cover border border-beige" />
              <% } else { %>
                <div class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center text-gray-300 text-xs">—</div>
              <% } %>
            </td>
            <td class="px-4 py-3 font-mono text-xs text-burgundy"><%= reg.referenceCode.slice(0, 12) %>...</td>
            <td class="px-4 py-3 text-maroon font-medium">
              <%= reg.child ? reg.child.name : reg.user.name %>
              <% if (reg.child && reg.child.age) { %><span class="text-xs text-burgundy/50">· <%= reg.child.age %>y</span><% } %>
            </td>
            <td class="px-4 py-3 text-burgundy text-xs"><%= reg.user.email %></td>
            <td class="px-4 py-3">
              <form method="POST" action="/admin/registrations/<%= reg.id %>/status">
                <select name="status" onchange="this.form.submit()"
                  class="text-xs border border-beige rounded px-2 py-1 bg-white">
                  <% ['PENDING','CONFIRMED','WAITLISTED','CANCELLED'].forEach(s => { %>
                    <option value="<%= s %>" <%= reg.status === s ? 'selected' : '' %>><%= s %></option>
                  <% }) %>
                </select>
              </form>
            </td>
            <td class="px-4 py-3">
              <form method="POST" action="/admin/registrations/<%= reg.id %>/payment">
                <select name="paymentStatus" onchange="this.form.submit()"
                  class="text-xs border border-beige rounded px-2 py-1 bg-white">
                  <% ['UNPAID','PARTIAL','PAID'].forEach(p => { %>
                    <option value="<%= p %>" <%= reg.paymentStatus === p ? 'selected' : '' %>><%= p %></option>
                  <% }) %>
                </select>
              </form>
            </td>
            <td class="px-4 py-3 text-xs text-burgundy"><%= new Date(reg.createdAt).toLocaleDateString() %></td>
            <td class="px-4 py-3 text-right">
              <button type="button" onclick="toggleDetails('<%= reg.id %>')"
                class="text-xs text-gold font-semibold hover:underline">Details</button>
            </td>
          </tr>

          <!-- Expandable details row -->
          <tr id="details-<%= reg.id %>" style="display:none" class="bg-gray-50/60 border-b border-gray-100">
            <td colspan="8" class="px-6 py-5">
              <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

                <!-- Photo + download -->
                <div>
                  <p class="text-xs tracking-wider uppercase text-gray-400 font-semibold mb-2">Attendee Photo</p>
                  <% if (reg.child && reg.child.photo) { %>
                    <img src="<%= reg.child.photo %>" alt="Attendee"
                      class="w-32 h-32 rounded-lg object-cover border border-beige mb-2" />
                    <br />
                    <a href="<%= reg.child.photo %>"
                      download="attendee-<%= (reg.child.name || 'photo').replace(/[^a-z0-9]/gi, '_') %>.jpg"
                      class="inline-block bg-gold text-maroon px-3 py-1.5 rounded text-xs font-semibold tracking-wider uppercase hover:bg-amber-500 transition-colors">
                      Download Photo
                    </a>
                  <% } else { %>
                    <p class="text-xs text-burgundy/50 italic">No photo uploaded.</p>
                  <% } %>
                </div>

                <!-- Attendee details -->
                <div>
                  <p class="text-xs tracking-wider uppercase text-gray-400 font-semibold mb-2">Attendee Details</p>
                  <dl class="text-xs text-maroon space-y-1">
                    <div><span class="text-burgundy/50">Name:</span> <%= reg.child ? reg.child.name : '—' %></div>
                    <div><span class="text-burgundy/50">Age:</span> <%= reg.child && reg.child.age ? reg.child.age : '—' %></div>
                    <div><span class="text-burgundy/50">School:</span> <%= reg.child && reg.child.school ? reg.child.school : '—' %></div>
                    <div><span class="text-burgundy/50">Dietary needs:</span> <%= reg.child && reg.child.dietaryNeeds ? reg.child.dietaryNeeds : '—' %></div>
                    <div><span class="text-burgundy/50">Medical notes:</span> <%= reg.child && reg.child.medicalNotes ? reg.child.medicalNotes : '—' %></div>
                    <div><span class="text-burgundy/50">Emergency contact:</span> <%= reg.child && reg.child.emergencyContact ? reg.child.emergencyContact : '—' %></div>
                    <div><span class="text-burgundy/50">Reference:</span> <span class="font-mono"><%= reg.referenceCode %></span></div>
                    <% if (reg.notes) { %><div><span class="text-burgundy/50">Notes:</span> <%= reg.notes %></div><% } %>
                  </dl>
                </div>

                <!-- Parent / Guardian -->
                <div>
                  <p class="text-xs tracking-wider uppercase text-gray-400 font-semibold mb-2">Parent / Guardian</p>
                  <dl class="text-xs text-maroon space-y-1">
                    <div><span class="text-burgundy/50">Name:</span> <%= reg.parentName || reg.user.name || '—' %></div>
                    <div><span class="text-burgundy/50">Address:</span> <%= reg.parentAddress || '—' %></div>
                    <div><span class="text-burgundy/50">Phone:</span> <%= reg.parentPhone || reg.user.phone || '—' %></div>
                    <div><span class="text-burgundy/50">Account email:</span> <%= reg.user.email %></div>
                  </dl>
                </div>

              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    <% if (registrations.length === 0) { %>
      <p class="text-center py-12 text-burgundy text-sm italic">No registrations yet.</p>
    <% } %>
  </div>
</main>

<script>
  function toggleDetails(id) {
    var row = document.getElementById('details-' + id);
    if (row) row.style.display = (row.style.display === 'none' || !row.style.display) ? 'table-row' : 'none';
  }
</script>
</body>
</html>
