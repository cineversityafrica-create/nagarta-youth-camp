<%- include('../partials/head', { title: 'Admin Login' }) %>
<div class="min-h-screen bg-white flex items-center justify-center p-4">
  <div class="w-full max-w-md">
    <div class="text-center mb-10">
      <div class="flex justify-center mb-3">
        <img src="/logo-full.png" alt="NAGARTA Youth Camp" class="h-36 object-contain" />
      </div>
      <p class="text-gray-400 text-sm tracking-widest uppercase mt-1">Admin Portal</p>
    </div>
    <div class="bg-white rounded-xl p-8 shadow-sm border border-gray-100">
      <h2 class="text-2xl font-serif font-semibold text-maroon mb-2">Sign In</h2>
      <p class="text-sm text-burgundy mb-6">Enter your admin credentials to continue.</p>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="bg-red-50 border border-red-200 text-red-700 rounded px-4 py-3 text-sm mb-4">
          <%= error %>
        </div>
      <% } %>

      <form method="POST" action="/admin/login" class="space-y-4" onsubmit="handleSubmit(event)">
        <div>
          <label class="block text-xs font-semibold tracking-wider uppercase text-burgundy mb-1" for="email">Email</label>
          <input type="email" id="email" name="email" required autocomplete="email"
            class="w-full px-4 py-3 border border-beige rounded bg-white text-maroon focus:outline-none focus:ring-2 focus:ring-gold text-sm" />
        </div>
        <div>
          <label class="block text-xs font-semibold tracking-wider uppercase text-burgundy mb-1" for="password">Password</label>
          <input type="password" id="password" name="password" required autocomplete="current-password"
            class="w-full px-4 py-3 border border-beige rounded bg-white text-maroon focus:outline-none focus:ring-2 focus:ring-gold text-sm"
            placeholder="••••••••" />
        </div>
        <button type="submit" id="submitBtn"
          class="w-full bg-gold text-maroon font-semibold py-3 rounded tracking-wider uppercase text-sm hover:bg-amber-500 transition-colors mt-2">
          Sign In
        </button>
      </form>

      <script>
        function handleSubmit(event) {
          const btn = document.getElementById('submitBtn');
          btn.disabled = true;
          btn.textContent = 'Signing in...';
          btn.classList.add('opacity-50');

          setTimeout(() => {
            event.target.submit();
          }, 100);
        }

        window.addEventListener('load', () => {
          console.log('Login form loaded successfully');
        });

        window.addEventListener('error', (event) => {
          console.error('Error:', event.error);
        });
      </script>
    </div>
    <p class="text-center text-xs text-gray-300 mt-6">NAGARTA Youth Camp 2026 &copy; Admin System</p>
  </div>
</div>
</body>
</html>
