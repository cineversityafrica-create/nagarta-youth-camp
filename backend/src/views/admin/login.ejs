<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Login — NAGARTA</title>
  <style>
    * { box-sizing:border-box; margin:0; padding:0; }
    body { font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; background:#f3eee9; min-height:100vh; display:flex; align-items:center; justify-content:center; padding:16px; color:#301317; }
    .box { width:100%; max-width:380px; }
    .head { text-align:center; margin-bottom:26px; }
    .head img { height:96px; object-fit:contain; }
    .head p { color:#999; font-size:12px; letter-spacing:3px; text-transform:uppercase; margin-top:6px; }
    .card { background:#fff; border-radius:16px; padding:30px; box-shadow:0 10px 30px rgba(0,0,0,.08); border:1px solid #eee; }
    .card h2 { font-size:24px; color:#301317; margin-bottom:4px; font-family:Georgia,serif; }
    .card .sub { color:#531c22; font-size:14px; margin-bottom:20px; }
    .err { background:#fef2f2; border:1px solid #fecaca; color:#b91c1c; padding:10px 14px; border-radius:8px; font-size:14px; margin-bottom:16px; }
    label { display:block; font-size:11px; font-weight:700; letter-spacing:1px; text-transform:uppercase; color:#531c22; margin-bottom:6px; }
    input { width:100%; padding:13px 14px; border:1px solid #decbb2; border-radius:8px; font-size:15px; margin-bottom:16px; color:#301317; background:#fff; }
    input:focus { outline:none; border-color:#cba36b; box-shadow:0 0 0 3px rgba(203,163,107,.25); }
    button { width:100%; padding:14px; background:#cba36b; color:#301317; font-weight:700; letter-spacing:1px; text-transform:uppercase; font-size:14px; border:none; border-radius:8px; cursor:pointer; }
    button:hover { background:#b8904f; }
    button:disabled { opacity:.5; }
    .foot { text-align:center; font-size:12px; color:#bbb; margin-top:18px; }
  </style>
</head>
<body>
  <div class="box">
    <div class="head">
      <img src="/logo-full.png" alt="NAGARTA Youth Camp" />
      <p>Admin Portal</p>
    </div>
    <div class="card">
      <h2>Sign In</h2>
      <p class="sub">Enter your admin credentials to continue.</p>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="err"><%= error %></div>
      <% } %>

      <form method="POST" action="/admin/login">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required autocomplete="email" />
        <label for="password">Password</label>
        <input type="password" id="password" name="password" required autocomplete="current-password" placeholder="••••••••" />
        <button type="submit" id="submitBtn">Sign In</button>
      </form>
    </div>
    <p class="foot">NAGARTA Youth Camp 2026 &copy; Admin System</p>
  </div>
  <script>
    document.querySelector('form').addEventListener('submit', function () {
      var b = document.getElementById('submitBtn'); b.disabled = true; b.textContent = 'Signing in…';
    });
  </script>
</body>
</html>
