<%- include('../partials/header') %>
<main class="main-content min-h-screen pt-20 md:pt-8 bg-gray-50">
  <%- include('../partials/sidebar') %>
  <div class="p-8">
    <p class="text-xs tracking-widest uppercase text-gold font-semibold mb-1">Notifications</p>
    <h2 class="font-serif text-3xl font-semibold text-maroon italic mb-8">Email Notifications</h2>

    <!-- Filters -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-8">
      <form method="GET" action="/admin/notifications" class="flex flex-col md:flex-row gap-4 md:items-end md:flex-wrap">
        <div class="flex flex-col gap-1.5">
          <label for="type" class="label-caps text-burgundy">Type</label>
          <select name="type" id="type" class="px-4 py-2 border border-beige rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gold bg-white">
            <option value="">All Types</option>
            <option value="REGISTRATION_CONFIRMATION" <%= filters.type === 'REGISTRATION_CONFIRMATION' ? 'selected' : '' %>>Registration Confirmation</option>
            <option value="PAYMENT_CONFIRMATION" <%= filters.type === 'PAYMENT_CONFIRMATION' ? 'selected' : '' %>>Payment Confirmation</option>
            <option value="STATUS_UPDATE" <%= filters.type === 'STATUS_UPDATE' ? 'selected' : '' %>>Status Update</option>
            <option value="ANNOUNCEMENT" <%= filters.type === 'ANNOUNCEMENT' ? 'selected' : '' %>>Announcement</option>
          </select>
        </div>

        <div class="flex flex-col gap-1.5">
          <label for="status" class="label-caps text-burgundy">Status</label>
          <select name="status" id="status" class="px-4 py-2 border border-beige rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gold bg-white">
            <option value="">All Statuses</option>
            <option value="SENT" <%= filters.status === 'SENT' ? 'selected' : '' %>>Sent</option>
            <option value="FAILED" <%= filters.status === 'FAILED' ? 'selected' : '' %>>Failed</option>
            <option value="BOUNCED" <%= filters.status === 'BOUNCED' ? 'selected' : '' %>>Bounced</option>
          </select>
        </div>

        <div class="flex flex-col gap-1.5">
          <label for="search" class="label-caps text-burgundy">Search</label>
          <input type="text" name="search" id="search" placeholder="Email or subject..." value="<%= filters.search %>" class="px-4 py-2 border border-beige rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gold bg-white">
        </div>

        <button type="submit" class="bg-gold text-maroon px-5 py-2 rounded-lg font-semibold tracking-wider uppercase text-sm hover:bg-amber-500 transition-colors">Filter</button>
        <a href="/admin/notifications" class="border border-gray-300 text-gray-700 px-5 py-2 rounded-lg font-semibold tracking-wider uppercase text-sm hover:bg-gray-100 transition-colors text-center">Clear</a>
      </form>
    </div>

    <!-- Success/Error Messages -->
    <% if (typeof success !== 'undefined' && success) { %>
      <div class="bg-green-50 border border-green-200 text-green-700 rounded-lg px-5 py-3 mb-6"><%= success %></div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="bg-red-50 border border-red-200 text-red-700 rounded-lg px-5 py-3 mb-6"><%= error %></div>
    <% } %>

    <!-- Notifications Table -->
    <% if (notifications && notifications.length > 0) { %>
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead class="bg-gray-50 border-b border-gray-100">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-semibold tracking-widest uppercase text-gray-600">Recipient Email</th>
                <th class="px-6 py-3 text-left text-xs font-semibold tracking-widest uppercase text-gray-600">Type</th>
                <th class="px-6 py-3 text-left text-xs font-semibold tracking-widest uppercase text-gray-600">Subject</th>
                <th class="px-6 py-3 text-left text-xs font-semibold tracking-widest uppercase text-gray-600">Status</th>
                <th class="px-6 py-3 text-left text-xs font-semibold tracking-widest uppercase text-gray-600">Sent At</th>
                <th class="px-6 py-3 text-left text-xs font-semibold tracking-widest uppercase text-gray-600">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% notifications.forEach(notif => { %>
                <tr class="border-b border-gray-50 hover:bg-gray-50 transition-colors">
                  <td class="px-6 py-3">
                    <div class="font-semibold text-maroon"><%= notif.recipientEmail %></div>
                    <% if (notif.user) { %>
                      <div class="text-sm text-gray-500"><%= notif.user.name %></div>
                    <% } %>
                  </td>
                  <td class="px-6 py-3">
                    <% if (notif.type === 'REGISTRATION_CONFIRMATION') { %>
                      <span class="inline-block bg-blue-100 text-blue-700 px-2 py-1 rounded text-xs font-semibold tracking-wider uppercase">Registration</span>
                    <% } else if (notif.type === 'PAYMENT_CONFIRMATION') { %>
                      <span class="inline-block bg-purple-100 text-purple-700 px-2 py-1 rounded text-xs font-semibold tracking-wider uppercase">Payment</span>
                    <% } else if (notif.type === 'STATUS_UPDATE') { %>
                      <span class="inline-block bg-amber-100 text-amber-700 px-2 py-1 rounded text-xs font-semibold tracking-wider uppercase">Status</span>
                    <% } else if (notif.type === 'ANNOUNCEMENT') { %>
                      <span class="inline-block bg-pink-100 text-pink-700 px-2 py-1 rounded text-xs font-semibold tracking-wider uppercase">Announcement</span>
                    <% } %>
                  </td>
                  <td class="px-6 py-3 text-sm"><%= notif.subject %></td>
                  <td class="px-6 py-3">
                    <% if (notif.status === 'SENT') { %>
                      <span class="inline-block bg-green-100 text-green-700 px-2 py-1 rounded text-xs font-semibold tracking-wider uppercase">Sent</span>
                    <% } else if (notif.status === 'FAILED') { %>
                      <span class="inline-block bg-red-100 text-red-700 px-2 py-1 rounded text-xs font-semibold tracking-wider uppercase">Failed</span>
                    <% } else if (notif.status === 'BOUNCED') { %>
                      <span class="inline-block bg-purple-100 text-purple-700 px-2 py-1 rounded text-xs font-semibold tracking-wider uppercase">Bounced</span>
                    <% } %>
                    <% if (notif.error) { %>
                      <div class="text-red-600 text-xs mt-1"><%= notif.error %></div>
                    <% } %>
                  </td>
                  <td class="px-6 py-3 text-sm text-gray-600"><%= new Date(notif.sentAt).toLocaleString('en-GB') %></td>
                  <td class="px-6 py-3">
                    <% if (notif.status === 'FAILED') { %>
                      <form method="POST" action="/admin/notifications/<%= notif.id %>/resend" style="display: inline;">
                        <button type="submit" class="bg-gold text-maroon px-3 py-1 rounded text-xs font-semibold hover:bg-amber-500 transition-colors">Resend</button>
                      </form>
                    <% } %>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    <% } else { %>
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-12 text-center">
        <p class="text-gray-400">No notifications found.</p>
      </div>
    <% } %>
  </div>
</main>

<%- include('../partials/footer') %>
