<%- include('../partials/head', { title: 'Volunteers' }) %>
<%- include('../partials/sidebar', { page: 'volunteers' }) %>

<main class="main-content p-4 md:p-8 min-h-screen bg-cream/30">
  <div class="mb-6">
    <h2 class="font-serif text-3xl font-semibold text-maroon italic">Volunteer Applications</h2>
    <p class="text-sm text-maroon/50 mt-1"><%= volunteers.length %> application<%= volunteers.length === 1 ? '' : 's' %></p>
  </div>

  <% if (volunteers.length === 0) { %>
    <div class="bg-white rounded-xl border border-beige p-10 text-center text-maroon/50">No volunteer applications yet.</div>
  <% } else { %>
  <div class="bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden">
    <div class="table-container">
    <table class="w-full text-sm">
      <thead>
        <tr class="bg-gray-50 text-left text-xs uppercase tracking-wider text-maroon/50">
          <th class="px-4 py-3">Name</th>
          <th class="px-4 py-3">Email</th>
          <th class="px-4 py-3">Phone</th>
          <th class="px-4 py-3">Applied</th>
          <th class="px-4 py-3">Status</th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody>
        <% volunteers.forEach(v => { %>
          <tr class="border-b border-gray-50 hover:bg-gray-50 cursor-pointer" onclick="toggleV('<%= v.id %>')">
            <td class="px-4 py-3 font-semibold text-maroon"><%= v.fullName %></td>
            <td class="px-4 py-3 text-maroon/70"><%= v.email %></td>
            <td class="px-4 py-3 text-maroon/70"><%= v.phone || '—' %></td>
            <td class="px-4 py-3 text-maroon/50 whitespace-nowrap"><%= new Date(v.createdAt).toLocaleDateString('en-GB', { day:'numeric', month:'short', year:'numeric' }) %></td>
            <td class="px-4 py-3">
              <span class="text-xs px-2.5 py-1 rounded-full font-bold <%= v.status === 'ACCEPTED' ? 'bg-green-100 text-green-700' : v.status === 'REJECTED' ? 'bg-red-100 text-red-700' : v.status === 'REVIEWED' ? 'bg-blue-100 text-blue-700' : 'bg-amber-100 text-amber-700' %>"><%= v.status %></span>
            </td>
            <td class="px-4 py-3 text-right"><button type="button" onclick="event.stopPropagation();toggleV('<%= v.id %>')" class="text-xs text-gold font-semibold hover:underline">Details</button></td>
          </tr>
          <tr id="v-<%= v.id %>" style="display:none" class="bg-cream/40 border-b border-gray-100">
            <td colspan="6" class="px-6 py-5">
              <div class="flex flex-wrap gap-2 mb-4">
                <% ['REVIEWED','ACCEPTED','REJECTED','PENDING'].forEach(s => { %>
                  <a href="/admin/volunteers/<%= v.id %>/status?status=<%= s %>" class="text-xs px-3 py-1.5 rounded-full border border-beige text-maroon/70 hover:bg-white">Mark <%= s.charAt(0) + s.slice(1).toLowerCase() %></a>
                <% }) %>
              </div>
              <% const idPhoto = (v.data || {}).idPhoto; %>
              <% if (idPhoto) { %>
                <div class="mb-4">
                  <p class="text-xs uppercase tracking-wider text-maroon/50 font-semibold mb-2">ID Photo</p>
                  <a href="<%= idPhoto %>" target="_blank" rel="noopener">
                    <img src="<%= idPhoto %>" alt="ID document" class="w-64 rounded-lg border border-beige hover:opacity-90 transition-opacity" />
                  </a>
                  <p class="text-[11px] text-maroon/40 mt-1">Click to open full size</p>
                </div>
              <% } %>
              <dl class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-1.5 text-sm">
                <% Object.entries(v.data || {}).forEach(([k, val]) => {
                     if (k === 'idPhoto') return; // rendered as an image above
                     const label = k.replace(/([A-Z])/g, ' $1').replace(/^./, c => c.toUpperCase());
                     let out = Array.isArray(val) ? val.join(', ') : (val && typeof val === 'object' ? JSON.stringify(val) : String(val ?? ''));
                     if (out === '' || out === 'null' || out === 'undefined') return; %>
                  <div class="flex gap-2 py-1 border-b border-beige/40">
                    <dt class="text-maroon/50 font-semibold min-w-[150px]"><%= label %></dt>
                    <dd class="text-maroon flex-1 whitespace-pre-wrap"><%= out %></dd>
                  </div>
                <% }) %>
              </dl>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    </div>
  </div>
  <% } %>
</main>

<script>
  function toggleV(id) {
    var el = document.getElementById('v-' + id);
    el.style.display = el.style.display === 'none' ? 'table-row' : 'none';
  }
</script>
</body>
</html>
