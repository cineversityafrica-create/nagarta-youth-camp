<%- include('../partials/head', { title: user.name + ' — Parent Portal' }) %>
<%- include('../partials/sidebar', { page: 'users' }) %>

<main class="main-content p-4 md:p-8">

  <!-- Back link -->
  <a href="/admin/users" class="inline-flex items-center gap-1.5 text-xs text-burgundy/60 hover:text-gold mb-6 transition-colors">
    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    Back to Users
  </a>

  <!-- Page heading -->
  <div class="flex items-start justify-between mb-8">
    <div>
      <p class="text-xs tracking-widest uppercase text-gold font-semibold mb-1">Parent Portal</p>
      <h2 class="font-serif text-3xl font-semibold text-maroon italic"><%= user.name || '(No name)' %></h2>
    </div>
    <span class="mt-1 text-xs px-3 py-1 rounded-full font-semibold
      <%= user.suspended ? 'bg-red-100 text-red-600' : 'bg-green-100 text-green-700' %>">
      <%= user.suspended ? 'Suspended' : 'Active' %>
    </span>
  </div>

  <!-- Parent details card -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-8">
    <p class="text-xs tracking-wider uppercase text-gray-400 font-semibold mb-4">Account Details</p>
    <dl class="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm">
      <div>
        <dt class="text-xs text-burgundy/50 mb-0.5">Email</dt>
        <dd class="text-maroon font-medium break-all"><%= user.email %></dd>
      </div>
      <div>
        <dt class="text-xs text-burgundy/50 mb-0.5">Phone</dt>
        <dd class="text-maroon font-medium"><%= user.phone || '—' %></dd>
      </div>
      <div>
        <dt class="text-xs text-burgundy/50 mb-0.5">Role</dt>
        <dd class="text-maroon font-medium"><%= user.role %></dd>
      </div>
      <div>
        <dt class="text-xs text-burgundy/50 mb-0.5">Joined</dt>
        <dd class="text-maroon font-medium"><%= new Date(user.createdAt).toLocaleDateString() %></dd>
      </div>
    </dl>
  </div>

  <!-- Campers section -->
  <div class="mb-4 flex items-center justify-between">
    <div>
      <p class="text-xs tracking-widest uppercase text-gold font-semibold mb-1">Registered Campers</p>
      <p class="text-sm text-burgundy/60"><%= user.registrations.length %> registration<%= user.registrations.length !== 1 ? 's' : '' %></p>
    </div>
  </div>

  <% if (user.registrations.length === 0) { %>
    <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-10 text-center">
      <p class="text-burgundy/50 text-sm italic">This parent has no registrations yet.</p>
    </div>
  <% } else { %>
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5">
      <% user.registrations.forEach(reg => { %>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">

          <!-- Camper photo banner -->
          <div class="relative h-40 bg-gray-50 flex items-center justify-center">
            <% if (reg.child && reg.child.photo) { %>
              <img src="<%= reg.child.photo %>" alt="<%= reg.child.name %>"
                class="w-full h-full object-cover cursor-pointer hover:opacity-90 transition-opacity"
                onclick="openPhotoModal(this.src)" title="Click to enlarge" />
              <!-- Action buttons -->
              <div class="absolute bottom-2 right-2 flex gap-1.5">
                <button type="button" onclick="openPhotoModal('<%= reg.child.photo %>')"
                  class="bg-white/90 hover:bg-white text-maroon text-xs px-2.5 py-1.5 rounded-full font-semibold tracking-wider uppercase flex items-center gap-1 transition-colors shadow">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                  </svg>
                  View
                </button>
                <a href="<%= reg.child.photo %>"
                  download="camper-<%= (reg.child.name || 'photo').replace(/[^a-z0-9]/gi, '_') %>.jpg"
                  class="bg-maroon/80 hover:bg-maroon text-gold text-xs px-2.5 py-1.5 rounded-full font-semibold tracking-wider uppercase flex items-center gap-1 transition-colors shadow">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
                  </svg>
                  Download
                </a>
              </div>
            <% } else { %>
              <div class="flex flex-col items-center gap-2 text-gray-300">
                <svg class="w-14 h-14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
                <span class="text-xs">No photo uploaded</span>
              </div>
            <% } %>
          </div>

          <!-- Camper info -->
          <div class="p-4">
            <div class="flex items-start justify-between mb-2">
              <div>
                <p class="text-maroon font-semibold text-sm"><%= reg.child ? reg.child.name : '(Self)' %></p>
                <% if (reg.child && reg.child.age) { %>
                  <p class="text-xs text-burgundy/50"><%= reg.child.age %> years old</p>
                <% } %>
              </div>
              <!-- Status badge -->
              <span class="text-xs px-2 py-0.5 rounded-full font-semibold
                <%= reg.status === 'CONFIRMED' ? 'bg-green-100 text-green-700' :
                   reg.status === 'PENDING'    ? 'bg-amber-100 text-amber-700' :
                   reg.status === 'WAITLISTED' ? 'bg-blue-100 text-blue-700'  :
                                                 'bg-red-100 text-red-600' %>">
                <%= reg.status %>
              </span>
            </div>

            <dl class="text-xs text-maroon space-y-1 mt-3">
              <% if (reg.child && reg.child.gender) { %>
                <div class="flex gap-1"><span class="text-burgundy/50 w-20 flex-shrink-0">Gender:</span><span><%= reg.child.gender %></span></div>
              <% } %>
              <% if (reg.child && reg.child.school) { %>
                <div class="flex gap-1"><span class="text-burgundy/50 w-20 flex-shrink-0">School:</span><span><%= reg.child.school %></span></div>
              <% } %>
              <% if (reg.child && reg.child.dietaryNeeds) { %>
                <div class="flex gap-1"><span class="text-burgundy/50 w-20 flex-shrink-0">Dietary:</span><span><%= reg.child.dietaryNeeds %></span></div>
              <% } %>
              <% if (reg.child && reg.child.medicalNotes) { %>
                <div class="flex gap-1"><span class="text-burgundy/50 w-20 flex-shrink-0">Medical:</span><span><%= reg.child.medicalNotes %></span></div>
              <% } %>
              <% if (reg.child && reg.child.emergencyContact) { %>
                <div class="flex gap-1"><span class="text-burgundy/50 w-20 flex-shrink-0">Emergency:</span><span><%= reg.child.emergencyContact %></span></div>
              <% } %>
            </dl>

            <!-- Reference + payment row -->
            <div class="mt-3 pt-3 border-t border-gray-100 flex items-center justify-between">
              <div>
                <p class="text-xs text-burgundy/40 mb-0.5">Reference</p>
                <p class="font-mono text-xs text-burgundy"><%= reg.referenceCode %></p>
              </div>
              <span class="text-xs px-2 py-0.5 rounded font-semibold
                <%= reg.paymentStatus === 'PAID'    ? 'bg-green-100 text-green-700' :
                   reg.paymentStatus === 'PARTIAL'  ? 'bg-amber-100 text-amber-700' :
                                                      'bg-gray-100 text-gray-500' %>">
                <%= reg.paymentStatus %>
              </span>
            </div>

            <!-- Print button -->
            <div class="mt-3 pt-3 border-t border-gray-100">
              <button type="button"
                onclick="printCamper(<%- JSON.stringify({
                  name:             reg.child ? reg.child.name             : '—',
                  age:              reg.child && reg.child.age             ? reg.child.age : '—',
                  school:           reg.child && reg.child.school          ? reg.child.school : '',
                  dietaryNeeds:     reg.child && reg.child.dietaryNeeds    ? reg.child.dietaryNeeds : '',
                  medicalNotes:     reg.child && reg.child.medicalNotes    ? reg.child.medicalNotes : '',
                  emergencyContact: reg.child && reg.child.emergencyContact? reg.child.emergencyContact : '',
                  photo:            reg.child && reg.child.photo           ? reg.child.photo : '',
                  referenceCode:    reg.referenceCode,
                  status:           reg.status,
                  paymentStatus:    reg.paymentStatus,
                  notes:            reg.notes || '',
                  parentName:       reg.parentName || user.name || '',
                  parentPhone:      reg.parentPhone || user.phone || '',
                  parentAddress:    reg.parentAddress || '',
                  parentEmail:      user.email,
                  registeredAt:     reg.createdAt
                }) %>)"
                class="w-full inline-flex items-center justify-center gap-2 bg-maroon text-gold px-4 py-2 rounded-lg text-xs font-semibold tracking-wider uppercase hover:bg-burgundy transition-colors">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/>
                </svg>
                Print Information
              </button>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>

</main>

<!-- Photo lightbox modal -->
<div id="photo-modal" onclick="closePhotoModal()"
  style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.85);cursor:zoom-out"
  class="flex items-center justify-center p-6">
  <div onclick="event.stopPropagation()" class="relative max-w-2xl w-full">
    <img id="photo-modal-img" src="" alt="Camper Photo"
      class="w-full max-h-[80vh] object-contain rounded-xl shadow-2xl" />
    <div class="flex gap-3 mt-4 justify-center">
      <button id="photo-modal-download"
        class="inline-flex items-center gap-2 bg-gold text-maroon px-5 py-2.5 rounded-full text-xs font-semibold tracking-wider uppercase hover:bg-amber-500 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
        </svg>
        Download
      </button>
      <button onclick="closePhotoModal()"
        class="inline-flex items-center gap-2 border border-white/30 text-white px-5 py-2.5 rounded-full text-xs font-semibold tracking-wider uppercase hover:bg-white/10 transition-colors">
        Close
      </button>
    </div>
  </div>
</div>

<script>
  /* ── Photo lightbox ─────────────────────────────────── */
  function openPhotoModal(src) {
    var modal = document.getElementById('photo-modal');
    var img   = document.getElementById('photo-modal-img');
    var dl    = document.getElementById('photo-modal-download');
    img.src   = src;
    dl.onclick = function() {
      var a = document.createElement('a');
      a.href = src; a.download = 'camper-photo.jpg'; a.click();
    };
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }
  function closePhotoModal() {
    document.getElementById('photo-modal').style.display = 'none';
    document.getElementById('photo-modal-img').src = '';
    document.body.style.overflow = '';
  }
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closePhotoModal();
  });

  /* ── Print camper info ──────────────────────────────── */
  function printCamper(d) {
    var date = d.registeredAt ? new Date(d.registeredAt).toLocaleDateString('en-GB', { day:'2-digit', month:'long', year:'numeric' }) : '—';
    var photoHtml = d.photo
      ? '<img src="' + d.photo + '" style="width:160px;height:160px;object-fit:cover;border-radius:8px;border:2px solid #decbb2;" />'
      : '<div style="width:160px;height:160px;border-radius:8px;border:2px dashed #decbb2;display:flex;align-items:center;justify-content:center;color:#aaa;font-size:12px;">No Photo</div>';

    function row(label, val) {
      if (!val) return '';
      return '<tr><td style="padding:5px 10px 5px 0;color:#531c22;font-size:11px;font-weight:600;white-space:nowrap;vertical-align:top;">' + label + '</td>'
           + '<td style="padding:5px 0;font-size:12px;color:#301317;">' + val + '</td></tr>';
    }

    var html = '<!DOCTYPE html><html><head><title>NAGARTA — ' + d.name + '</title>'
      + '<style>'
      + 'body{font-family:Georgia,serif;margin:0;padding:32px;color:#301317;background:#fff;}'
      + '@media print{body{padding:20px;}}'
      + '.header{background:#301317;color:#cba36b;padding:14px 20px;border-radius:8px;margin-bottom:24px;display:flex;align-items:center;justify-content:space-between;}'
      + '.header h1{margin:0;font-size:22px;letter-spacing:2px;}'
      + '.header p{margin:0;font-size:10px;letter-spacing:3px;text-transform:uppercase;opacity:.7;}'
      + '.body{display:flex;gap:28px;}'
      + '.photo-col{flex-shrink:0;}'
      + '.info-col{flex:1;}'
      + '.section-title{font-size:9px;letter-spacing:3px;text-transform:uppercase;color:#531c22;font-family:Arial,sans-serif;margin:0 0 6px;border-bottom:1px solid #decbb2;padding-bottom:4px;}'
      + 'table{border-collapse:collapse;width:100%;}'
      + '.badge{display:inline-block;padding:2px 8px;border-radius:20px;font-size:10px;font-weight:700;font-family:Arial,sans-serif;letter-spacing:1px;text-transform:uppercase;}'
      + '.ref{font-family:monospace;font-size:13px;font-weight:700;color:#531c22;letter-spacing:2px;}'
      + '.footer{margin-top:28px;border-top:1px solid #decbb2;padding-top:10px;font-size:9px;color:#aaa;text-align:center;letter-spacing:1px;}'
      + '</style></head><body>'

      + '<div class="header">'
      +   '<div><h1>NAGARTA Youth Camp 2026</h1><p>Camper Registration Record</p></div>'
      +   '<div style="text-align:right;font-size:10px;opacity:.7;">Printed ' + new Date().toLocaleDateString('en-GB') + '</div>'
      + '</div>'

      + '<div class="body">'

      +   '<div class="photo-col">'
      +     photoHtml
      +     '<div style="margin-top:10px;text-align:center;">'
      +       '<span class="badge" style="background:#decbb2;color:#301317;">' + d.status + '</span>'
      +       '&nbsp;<span class="badge" style="background:#f3eee9;color:#531c22;">' + d.paymentStatus + '</span>'
      +     '</div>'
      +   '</div>'

      +   '<div class="info-col">'

      +     '<p class="section-title">Camper Details</p>'
      +     '<table>'
      +       row('Full Name',         d.name)
      +       row('Age',               d.age ? d.age + ' years' : '')
      +       row('School',            d.school)
      +       row('Dietary Needs',     d.dietaryNeeds)
      +       row('Medical Notes',     d.medicalNotes)
      +       row('Emergency Contact', d.emergencyContact)
      +       row('Notes',             d.notes)
      +     '</table>'

      +     '<br/>'
      +     '<p class="section-title">Parent / Guardian</p>'
      +     '<table>'
      +       row('Name',    d.parentName)
      +       row('Phone',   d.parentPhone)
      +       row('Address', d.parentAddress)
      +       row('Email',   d.parentEmail)
      +     '</table>'

      +     '<br/>'
      +     '<p class="section-title">Registration</p>'
      +     '<p class="ref">' + d.referenceCode + '</p>'
      +     '<p style="font-size:11px;color:#531c22;margin:4px 0 0;">Registered: ' + date + '</p>'

      +   '</div>'
      + '</div>'

      + '<div class="footer">NAGARTA Youth Camp 2026 &nbsp;·&nbsp; Admin Record &nbsp;·&nbsp; Confidential</div>'
      + '</body></html>';

    var win = window.open('', '_blank', 'width=800,height=650');
    win.document.write(html);
    win.document.close();
    win.focus();
    win.onload = function() { win.print(); };
  }
</script>
</body>
</html>
