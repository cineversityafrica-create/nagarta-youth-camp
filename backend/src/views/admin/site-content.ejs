<%- include('../partials/head', { title: 'Site Content' }) %>
<%- include('../partials/sidebar', { page: 'site-content' }) %>

<main class="main-content p-4 md:p-8">
  <div class="mb-8">
    <p class="text-xs tracking-widest uppercase text-gold font-semibold mb-1">Edit</p>
    <h2 class="font-serif text-3xl font-semibold text-maroon italic">Site Content</h2>
    <p class="text-sm text-burgundy mt-1">Changes appear on the public site within 60 seconds.</p>
  </div>

  <% if (typeof success !== 'undefined' && success) { %>
    <div class="bg-green-50 border border-green-200 text-green-700 rounded px-4 py-3 text-sm mb-6"><%= success %></div>
  <% } %>

  <%
    const groups = {};
    items.forEach(item => {
      if (!groups[item.group]) groups[item.group] = [];
      groups[item.group].push(item);
    });
  %>

  <% Object.entries(groups).forEach(([group, groupItems]) => { %>
    <div class="bg-white rounded-lg shadow-sm p-6 mb-6">
      <h3 class="font-serif text-lg font-semibold text-maroon capitalize mb-4 border-b border-beige pb-3"><%= group %></h3>
      <div class="space-y-4">
        <% groupItems.forEach(item => { %>
          <form method="POST" action="/admin/site-content/<%= item.key %>">
            <input type="hidden" name="_method" value="PUT" />
            <label class="block text-xs tracking-wider uppercase text-burgundy font-semibold mb-1"><%= item.label %></label>
            <% if (item.value.length > 100) { %>
              <textarea name="value" rows="3"
                class="w-full px-3 py-2 border border-beige rounded text-sm text-maroon focus:outline-none focus:ring-2 focus:ring-gold"><%= item.value %></textarea>
            <% } else { %>
              <input type="text" name="value" value="<%= item.value %>"
                class="w-full px-3 py-2 border border-beige rounded text-sm text-maroon focus:outline-none focus:ring-2 focus:ring-gold" />
            <% } %>
            <button type="submit" class="mt-2 text-xs bg-gold text-maroon px-3 py-1 rounded font-semibold tracking-wider uppercase hover:bg-amber-500 transition-colors">
              Save
            </button>
          </form>
        <% }) %>
      </div>
    </div>
  <% }) %>
</main>
</body>
</html>
