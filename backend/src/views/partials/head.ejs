<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title + ' — NAGARTA Admin' : 'NAGARTA Admin' %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            burgundy: '#531c22',
            maroon:   '#301317',
            gold:     '#cba36b',
            cream:    '#f3eee9',
            beige:    '#decbb2',
          },
          fontFamily: {
            serif: ['Georgia', 'Cambria', 'serif'],
          }
        }
      }
    }
  </script>
  <style>
    body { background-color: #ffffff; margin: 0; padding: 0; }
    .sidebar-link:hover { background: rgba(83,28,34,0.06); }
    .sidebar-link.active { border-left: 3px solid currentColor; font-weight: 600; }
    .nav-dashboard.active   { background: rgba(59,130,246,0.12);  color: #1d6fce; }
    .nav-registrations.active { background: rgba(249,115,22,0.12); color: #c2510a; }
    .nav-content.active     { background: rgba(168,85,247,0.12);  color: #7e22ce; }
    .nav-activities.active  { background: rgba(20,184,166,0.12);  color: #0f7a6e; }
    .nav-schedule.active    { background: rgba(99,102,241,0.12);  color: #4338ca; }
    .nav-announcements.active { background: rgba(244,63,94,0.12); color: #be123c; }
    .nav-messages.active    { background: rgba(74,183,96,0.12);   color: #2d7a3e; }
    .nav-users.active       { background: rgba(234,179,8,0.12);   color: #92660a; }
    .nav-payments.active    { background: rgba(59,130,246,0.12);  color: #1d6fce; }
    .nav-notifications.active { background: rgba(83,28,34,0.12);  color: #531c22; }

    /* DESKTOP LAYOUT (>= 768px) */
    @media (min-width: 768px) {
      .mobile-header { display: none !important; }
      .sidebar {
        display: flex !important;
        position: fixed;
        left: 0;
        top: 0;
        width: 16rem;
        height: 100vh;
        z-index: 30;
      }
      .main-content {
        margin-left: 16rem !important;
        padding-top: 2rem !important;
      }
    }

    /* MOBILE LAYOUT (< 768px) */
    @media (max-width: 767px) {
      .sidebar {
        display: none;
        position: fixed;
        left: 0;
        top: 0;
        width: 16rem;
        height: 100vh;
        z-index: 50;
      }
      #sidebar-toggle:checked ~ .sidebar { display: flex; }
      #sidebar-toggle:checked ~ .sidebar-overlay {
        display: block;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.4);
        z-index: 40;
      }
      .sidebar-overlay { display: none; }
      .main-content {
        margin-left: 0 !important;
        padding-top: 4rem !important;
      }
      .table-container { overflow-x: auto; }
    }
  </style>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400;1,600&display=swap" rel="stylesheet">
</head>
<body class="font-sans text-maroon">
