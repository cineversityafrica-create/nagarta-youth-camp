generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  password      String
  name          String
  phone         String?
  role          String         @default("CAMPER") // PARENT | CAMPER | ADMIN
  suspended     Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  registrations Registration[]
  children      Child[]
  notifications Notification[]
  @@map("users")
}

model Child {
  id               String         @id @default(cuid())
  parentId         String
  parent           User           @relation(fields: [parentId], references: [id], onDelete: Cascade)
  name             String
  age              Int
  gender           String?  // Male | Female | Other
  school           String?
  dietaryNeeds     String?
  medicalNotes     String?
  emergencyContact String?
  photo            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  registrations    Registration[]

  @@index([parentId])
  @@map("children")
}

model Registration {
  id               String   @id @default(cuid())
  referenceCode    String   @unique @default(cuid())
  userId           String
  // Cascade: deleting a parent account must remove their registrations, which
  // in turn cascade to payments and check-in logs. Without this the database
  // refuses the delete and the admin Delete link fails.
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  childId          String?
  child            Child?   @relation(fields: [childId], references: [id])
  type             String   @default("SELF")    // SELF | CHILD
  status           String   @default("PENDING") // PENDING | CONFIRMED | WAITLISTED | CANCELLED
  paymentStatus    String   @default("UNPAID")  // UNPAID | PARTIAL | PAID
  notes            String?
  // "How did you hear about NAGARTA?" — heardFromDetail holds the free text
  // typed when the answer is Other.
  heardFrom        String?
  heardFromDetail  String?
  parentName       String?
  parentAddress    String?
  parentPhone      String?
  // Mother's information
  motherName       String?
  motherAddress    String?
  motherPhone      String?
  motherEmail      String?
  motherEmergencyContact String?
  // Father's information
  fatherName       String?
  fatherAddress    String?
  fatherPhone      String?
  fatherEmail      String?
  fatherEmergencyContact String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  campId           Int?                 @unique // printed ID-card number (1–1000), assigned at first check-in
  transactions     PaymentTransaction[]
  notifications    Notification[]
  checkLogs        CheckLog[]

  @@index([status])
  @@index([paymentStatus])
  @@index([userId])
  @@index([createdAt])
  @@map("registrations")
}

// Camp gate check-in / check-out events with the guardian's details captured
// at the point of arrival/pickup.
// A check event for either a camper (registrationId) or a volunteer
// (volunteerId). Exactly one of the two is set; this is enforced in the route,
// since Prisma cannot express the constraint.
model CheckLog {
  id              String                @id @default(cuid())
  registrationId  String?
  registration    Registration?         @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  volunteerId     String?
  volunteer       VolunteerApplication? @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  type            String                // IN | OUT
  guardianName    String?
  guardianAddress String?
  guardianPhone   String?
  ghanaCard       String?
  createdAt       DateTime              @default(now())

  @@index([registrationId])
  @@index([volunteerId])
  @@index([createdAt])
  @@map("check_logs")
}

model PaymentTransaction {
  id             String       @id @default(cuid())
  registrationId String
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  amount         Int          // stored in pesewas/kobo (amount × 100)
  currency       String       @default("GHS")
  method         String       // CASH | VISA | MOBILE_MONEY
  reference      String?      // Paystack reference or manual note
  note           String?
  createdAt      DateTime     @default(now())
  @@map("payment_transactions")
}

model Notification {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  registrationId String?
  registration   Registration? @relation(fields: [registrationId], references: [id], onDelete: SetNull)

  type           String        // REGISTRATION_CONFIRMATION | PAYMENT_CONFIRMATION | STATUS_UPDATE | ANNOUNCEMENT
  subject        String
  recipientEmail String
  template       String        // Template name used
  status         String        @default("SENT") // SENT | FAILED | BOUNCED
  sentAt         DateTime      @default(now())
  error          String?       // Error message if status is FAILED

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  @@map("notifications")
}

model Activity {
  id           String   @id @default(cuid())
  title        String
  subtitle     String
  iconName     String   @default("star")
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@map("activities")
}

model ScheduleDay {
  id        String   @id @default(cuid())
  dayNumber Int      @unique
  date      String
  title     String
  summary   String
  details   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("schedule_days")
}

model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  label     String
  group     String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("site_content")
}

model Testimonial {
  id           String   @id @default(cuid())
  name         String   // Testimonial author
  role         String?  // e.g., "Camper", "Parent", "Alumni"
  quote        String   // The testimonial text
  published    Boolean  @default(true)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@map("testimonials")
}

// Volunteer applications. Core identity fields are columns for quick admin
// scanning; the full multi-section questionnaire is stored in `data` (JSON).
model VolunteerApplication {
  id            String     @id @default(cuid())
  // Scanned or typed at the check-in station, exactly like a camper's code.
  // Nullable so applications submitted before this existed remain valid.
  referenceCode String?    @unique
  campId        Int?       @unique // badge number, assigned on first check-in
  fullName      String
  email         String
  phone         String?
  skills        String?    // comma-joined skills for quick scanning
  data          Json       // the complete questionnaire (all sections)
  status        String     @default("PENDING") // PENDING | REVIEWED | ACCEPTED | REJECTED
  createdAt     DateTime   @default(now())
  checkLogs     CheckLog[]

  @@index([createdAt])
  @@map("volunteer_applications")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("contact_messages")
}

model Announcement {
  id         String   @id @default(cuid())
  title      String
  body       String
  published  Boolean  @default(true)
  targetRole String?  // null = all | PARENT | CAMPER
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  @@map("announcements")
}
